# ============================================
# PADEL GAME ANALYZER — .gitignore
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# YOLO Models (too large for git)
models/*.pt
models/*.onnx

# Video files (ignore globally)
*.mp4
*.avi
*.mov
*.mkv

# BUT allow sample videos folder
!videos/
!videos/*.mp4


# Output files (regenerated by pipeline)
output/*.json
output/*.txt
output/*.png

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# Distribution
dist/
build/
*.egg-info/

# Logs
*.log

# Temp
tmp/
*.tmp

# Windows path artifacts
C\:\\*
